# =============================================================
# .env.example — MODATA.AGENT
# Copy thành .env và điền giá trị thực
# =============================================================

# ── APP ──────────────────────────────────────────────────────
APP_NAME=MODATA Agent
DEBUG=false
LOG_LEVEL=INFO

# ── LLM SERVER (remote) ──────────────────────────────────────
LLM_BASE_URL=http://192.168.100.114:8088/v1
LLM_API_KEY=
LLM_MODEL=qwen3-8b
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=60
LLM_ENABLE_THINKING=false

# ── KEYCLOAK ─────────────────────────────────────────────────
KEYCLOAK_URL=https://sso.hitc.vn/auth
KEYCLOAK_REALM=vtqt
KEYCLOAK_CLIENT_ID=vtqt

# ── MONGODB (permission lookup) ───────────────────────────────
MONGO_URI=mongodb://admin:password@mongo-host:27017/admin?authSource=admin
MONGO_DATABASE=generic_instance_v2

# ── POSTGRESQL (session store) ────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_USER=admin
PG_PASSWORD=change_me
PG_DATABASE=vectordb

# ── REDIS (permission store) ─────────────────────────────────
# Dùng chung Redis instance với modata-mcp nếu có
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# TTL quyền truy cập (giây): 28800 = 8 giờ
SESSION_PERM_TTL=28800

# ── MCP GATEWAY (modata-mcp) ──────────────────────────────────
# Trỏ đến modata-mcp project đang chạy
MCP_GATEWAY_URL=http://localhost:8001/sse
MCP_TIMEOUT=60

# ── SECURITY ─────────────────────────────────────────────────
INTERNAL_API_KEY=change_me_to_a_strong_random_key

# ── SESSION ──────────────────────────────────────────────────
RAG_MAX_HISTORY=20
SESSION_TTL_DAYS=30

# ── COMPANY ──────────────────────────────────────────────────
DEFAULT_COMPANY_CODE=HITC